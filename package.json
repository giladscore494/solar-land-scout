{
  "name": "solar-land-scout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:health": "tsx scripts/db-health.ts",
    "db:repair:optional": "tsx scripts/repair-optional-schema.ts",
    "db:init": "psql \"$SUPABASE_DATABASE_URL\" -f db/migrations/001_create_parcel_scan_tables.sql",
    "db:init:check": "tsx scripts/db-init-check.ts",
    "import:parcels:source": "tsx scripts/import-parcels.ts --source",
    "import:parcels:az": "tsx scripts/import-parcels.ts --group az",
    "import:parcels:statewide": "tsx scripts/import-parcels.ts --group statewide",
    "import:parcels:plss": "tsx scripts/import-parcels.ts --source blm_natl_plss",
    "import:parcels:all-enabled": "tsx scripts/import-parcels.ts --all-enabled",
    "parcels:unify": "tsx scripts/unify-parcels.ts",
    "parcels:report": "tsx scripts/parcel-source-report.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.50.1",
    "maplibre-gl": "^4.7.1",
    "next": "15.5.15",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shapefile": "^0.6.6",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/shapefile": "^0.6.3",
    "@types/topojson-client": "^3.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
