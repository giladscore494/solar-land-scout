# Gemini API (server-side only). Used for natural-language explanations and
# grounded weak-field completion via Gemini 3 Pro.
GEMINI_API_KEY=
# Optional override. Defaults to `gemini-3-pro-preview`.
GEMINI_MODEL=
# Opt-in for Google Maps grounding (Vertex-only preview). Default: off.
# When off, debug honestly reports maps_context as unavailable in this API path.
GEMINI_ENABLE_MAPS_GROUNDING=

# Anthropic Claude API key (server-side only). Used as LLM fallback when
# Gemini is unavailable. Model: claude-opus-4-5.
ANTHROPIC_API_KEY=

# NREL API key. Used for solar resource enrichment.
NREL_API_KEY=

# MapTiler / MapLibre vector tile key (client-side, public by design).
NEXT_PUBLIC_MAPTILER_KEY=

# Set to "true" to expose /api/analysis-runs/:id/debug in production.
ENABLE_DEBUG_JSON=

# Mapbox public token (client-side, `pk.` prefix). Enables the satellite
# raster basemap toggle. The app degrades gracefully when missing — the
# toggle is simply hidden.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Cloud API key with Solar API enabled. Tier 2 enrichment; the app
# works without it. Optional cap override (defaults to 100 calls / lifetime):
GOOGLE_SOLAR_API_KEY=
GOOGLE_SOLAR_DAILY_CAP=

# Supabase / PostGIS spatial database. Required for parcel engine.
# Use the "Transaction" pooler URL from Supabase project settings.
SUPABASE_DATABASE_URL=
# Supabase public (anon) key — safe to expose to clients.
SUPABASE_PUBLISHABLE_KEY=
# Supabase service role key — server-side only, never expose to clients.
SUPABASE_SECRET_KEY=

# Admin import token. Required header (x-admin-token) for POST /api/admin/import-data.
ADMIN_IMPORT_TOKEN=
