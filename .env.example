# Gemini API (server-side only). Used for explanation + enrichment fallbacks.
GEMINI_API_KEY=

# NREL API key. Used for point-level solar resource enrichment during analysis runs.
NREL_API_KEY=

# MapTiler / MapLibre vector tile key (client-side, public by design).
NEXT_PUBLIC_MAPTILER_KEY=

# PostgreSQL connection string. Railway provides this automatically when Postgres is attached.
DATABASE_URL=
